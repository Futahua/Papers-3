+ipcMain.handle('hermes:papers:update', async () => {
+  if (!papersDockPost) {
+    return { ok: false, error: 'papers-unavailable', message: 'Papers is not connected.' }
+  }
+
+  const delivered = await papersDockPost({ phase: 'update-request' })
+
+  if (!delivered) {
+    return { ok: false, error: 'papers-unavailable', message: 'Papers did not accept the update request.' }
+  }
+
+  emitUpdateProgress({
+    stage: 'restart',
+    message: 'Papers is closing Hermes, updating it, and reopening both applications.',
+    percent: 100
+  })
+  isQuittingForHandoff = true
+  setTimeout(() => app.quit(), 1200)
+
+  return { ok: true, handedOff: true, message: 'Papers update helper started.' }
+})
