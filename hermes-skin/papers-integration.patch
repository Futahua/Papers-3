+// ─── Papers companion-window seam ──────────────────────────────────────────
+// This is the only native integration Papers carries in Hermes. It is inert
+// unless Papers launches Hermes with an authenticated loopback endpoint.
+type PapersDockPayload = {
+  phase: string
+  bounds?: Electron.Rectangle
+  controlPort?: number | null
+  maximized?: boolean
+  minimized?: boolean
+  focused?: boolean
+  display?: number | null
+}
+
+let papersDockPost: ((payload: PapersDockPayload) => Promise<boolean>) | null = null
+
+function installPapersDockReporter(win: BrowserWindow) {
+  const dockUrl = process.env.HERMES_DESKTOP_PAPERS_DOCK_URL
+  const dockToken = process.env.HERMES_DESKTOP_PAPERS_DOCK_TOKEN
+
+  if (!dockUrl || !dockToken || !win || win.isDestroyed()) return
+
+  let endpoint: URL
+
+  try {
+    endpoint = new URL(dockUrl)
+  } catch {
+    return
+  }
+
+  const post = (payload: PapersDockPayload): Promise<boolean> =>
+    new Promise(resolvePost => {
+      try {
+        const body = Buffer.from(JSON.stringify(payload))
+        const req = http.request(
+          {
+            hostname: endpoint.hostname,
+            port: endpoint.port,
+            path: endpoint.pathname || '/',
+            method: 'POST',
+            headers: {
+              'content-type': 'application/json',
+              'content-length': body.length,
+              'x-papers-dock-token': dockToken
+            },
+            timeout: 1000
+          },
+          res => {
+            res.resume()
+            res.once('end', () => resolvePost(Boolean(res.statusCode && res.statusCode >= 200 && res.statusCode < 300)))
+          }
+        )
+
+        req.once('error', () => resolvePost(false))
+        req.once('timeout', () => {
+          req.destroy()
+          resolvePost(false)
+        })
+        req.end(body)
+      } catch {
+        resolvePost(false)
+      }
+    })
+
+  papersDockPost = post
+
+  const report = (phase: string) => {
+    if (win.isDestroyed()) return
+    const bounds = win.getBounds()
+
+    void post({
+      phase,
+      bounds,
+      maximized: win.isMaximized(),
+      minimized: win.isMinimized(),
+      focused: win.isFocused(),
+      display: (() => {
+        try {
+          return screen.getDisplayMatching(bounds).id
+        } catch {
+          return null
+        }
+      })()
+    })
+  }
+
+  let moveTimer: NodeJS.Timeout | null = null
+  const scheduleMove = () => {
+    if (moveTimer) return
+    moveTimer = setTimeout(() => {
+      moveTimer = null
+      report('move')
+    }, 16)
+  }
+
+  win.on('move', scheduleMove)
+  win.on('resize', scheduleMove)
+  win.on('moved', () => report('settle'))
+  win.on('resized', () => report('settle'))
+  win.on('maximize', () => report('settle'))
+  win.on('unmaximize', () => report('settle'))
+  win.on('restore', () => report('settle'))
+  win.on('minimize', () => report('settle'))
+  win.on('focus', () => report('focus'))
+  win.on('show', () => report('settle'))
+
+  const server = http.createServer((req, res) => {
+    if (req.method !== 'POST' || req.headers['x-papers-dock-token'] !== dockToken) {
+      res.writeHead(req.method === 'POST' ? 401 : 405)
+      res.end()
+      return
+    }
+
+    let raw = ''
+    req.on('data', chunk => {
+      raw += chunk
+      if (raw.length > 4096) req.destroy()
+    })
+    req.on('end', () => {
+      try {
+        const command = JSON.parse(raw || '{}')
+
+        if (win.isDestroyed()) {
+          res.writeHead(410)
+          res.end()
+          return
+        }
+
+        if (command.op === 'setBounds' && command.bounds) {
+          const next = command.bounds
+          const valid = [next.x, next.y, next.width, next.height].every(Number.isFinite)
+
+          if (!valid || next.width < 320 || next.height < 300) throw new Error('Invalid window bounds')
+          if (win.isMaximized()) win.unmaximize()
+          if (win.isMinimized()) win.restore()
+          win.setBounds({
+            x: Math.round(next.x),
+            y: Math.round(next.y),
+            width: Math.round(next.width),
+            height: Math.round(next.height)
+          })
+          if (command.focus) win.focus()
+          if (command.raise) win.moveTop()
+        } else if (command.op === 'focus') {
+          if (win.isMinimized()) win.restore()
+          win.show()
+          win.focus()
+        } else if (command.op === 'minimize') {
+          win.minimize()
+        } else if (command.op === 'raise') {
+          win.moveTop()
+        }
+
+        res.writeHead(200, { 'content-type': 'application/json' })
+        res.end(JSON.stringify({ ok: true, bounds: win.getBounds() }))
+      } catch (error) {
+        res.writeHead(400, { 'content-type': 'application/json' })
+        res.end(JSON.stringify({ ok: false, error: String(error) }))
+      }
+    })
+  })
+
+  server.on('error', () => {})
+  server.listen(0, '127.0.0.1', () => {
+    const address = server.address()
+    const controlPort = address && typeof address === 'object' ? address.port : null
+
+    void post({ phase: 'hello', controlPort, bounds: win.getBounds() })
+  })
+  win.once('closed', () => {
+    papersDockPost = null
+    void post({ phase: 'closed' })
+    server.close()
+  })
+  report('settle')
+}
